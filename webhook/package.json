{
  "name": "fumireply-webhook",
  "version": "1.0.0",
  "type": "module",
  "engines": { "node": ">=24.0.0" },
  "scripts": {
    "build": "esbuild src/handler.ts --bundle --platform=node --target=node24 --format=cjs --outfile=dist/handler.js --external:@aws-sdk/*",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@aws-sdk/client-sqs": "^3.1039.0",
    "@aws-sdk/client-ssm": "^3.1039.0",
    "drizzle-orm": "^0.45.2",
    "postgres": "^3.4.9",
    "zod": "^4.4.1"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.149",
    "@types/node": "^25.6.0",
    "aws-sdk-client-mock": "^4.1.0",
    "esbuild": "^0.25.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
