# Supabase
DATABASE_URL=postgresql://postgres:password@localhost:54322/postgres
SUPABASE_SERVICE_ROLE_KEY=

# AWS / SQS
AWS_REGION=ap-northeast-1

# Summary pipeline (003-customer-context-and-settings)
# SQS queue URL for summary jobs (this Lambda consumes from here)
AI_SUMMARY_QUEUE_URL=https://sqs.ap-northeast-1.amazonaws.com/123456789012/ai-summary-queue
# Character threshold to trigger summary job (default 2000)
SUMMARY_TRIGGER_THRESHOLD_CHARS=2000
# Set to false to disable the summary pipeline entirely
SUMMARY_PIPELINE_ENABLED=true

# Anthropic
ANTHROPIC_API_KEY_SSM_KEY=/fumireply/review/anthropic/api-key
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
