# Supabase
DATABASE_URL=postgresql://postgres:password@localhost:54322/postgres
SUPABASE_URL=http://localhost:54321
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# AWS / SQS
AWS_REGION=ap-northeast-1
# Same draft queue used by webhook (see webhook/.env). Required for the
# regenerate-draft server fn to publish jobs to ai-worker (feature 005).
SQS_QUEUE_URL=https://sqs.ap-northeast-1.amazonaws.com/123456789012/ai-draft-queue

# Summary pipeline (003-customer-context-and-settings)
# SQS queue URL for summary jobs. Leave empty to disable.
AI_SUMMARY_QUEUE_URL=
# Character threshold to trigger summary job (default 2000)
SUMMARY_TRIGGER_THRESHOLD_CHARS=2000
# Set to false to disable the summary pipeline entirely
SUMMARY_PIPELINE_ENABLED=true

# Anthropic
ANTHROPIC_API_KEY_SSM_KEY=/fumireply/review/anthropic/api-key

# App
VITE_APP_URL=http://localhost:3000
