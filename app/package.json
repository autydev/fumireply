{
  "name": "fumireply-app",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "start": "node .output/server/index.mjs",
    "gen:routes": "tsr generate",
    "pretypecheck": "npm run paraglide:compile && npm run gen:routes",
    "pretest": "npm run paraglide:compile && npm run gen:routes",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "lint": "eslint src tests --no-error-on-unmatched-pattern",
    "db:migrate": "drizzle-kit migrate",
    "db:seed:review": "tsx src/server/db/seed/review.ts",
    "db:seed:e2e": "tsx --env-file-if-exists=.env --env-file-if-exists=.env.local src/server/db/seed/e2e.ts",
    "paraglide:compile": "paraglide-js compile --project ./project.inlang --outdir ./src/paraglide --emit-ts-declarations",
    "predev": "npm run paraglide:compile",
    "prebuild": "npm run paraglide:compile"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.111.0",
    "@aws-sdk/client-s3": "^3.1090.0",
    "@aws-sdk/client-ssm": "^3.1090.0",
    "@aws-sdk/s3-request-presigner": "^3.1090.0",
    "@supabase/supabase-js": "^2.110.2",
    "@tanstack/react-router": "^1.170.17",
    "@tanstack/react-start": "^1.168.27",
    "drizzle-orm": "^0.45.2",
    "nitro": "^3.0.260429-beta",
    "postgres": "^3.4.9",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zod": "^4.4.1"
  },
  "devDependencies": {
    "@aws-sdk/client-sqs": "^3.1085.0",
    "@eslint/js": "^10.0.1",
    "@inlang/paraglide-js": "^2.21.0",
    "@inlang/plugin-message-format": "^4.4.0",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/vite": "^4.3.2",
    "@tanstack/router-cli": "^1.167.18",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/aws-lambda": "^8.10.162",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.10",
    "aws-sdk-client-mock": "^4.1.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "jsdom": "^29.1.1",
    "msw": "^2.15.0",
    "prettier": "^3.9.5",
    "tailwindcss": "^4.2.4",
    "tsx": "^4.23.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.63.0",
    "vite": "^8.1.4",
    "vitest": "^4.1.5"
  }
}
