{
  "name": "fumireply-app",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "start": "node .output/server/index.mjs",
    "gen:routes": "tsr generate",
    "pretypecheck": "npm run gen:routes",
    "pretest": "npm run gen:routes",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "lint": "eslint src tests --no-error-on-unmatched-pattern",
    "db:migrate": "drizzle-kit migrate",
    "db:seed:review": "tsx src/server/db/seed/review.ts",
    "db:seed:e2e": "tsx --env-file-if-exists=.env --env-file-if-exists=.env.local src/server/db/seed/e2e.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.91.1",
    "@aws-sdk/client-ssm": "^3.1039.0",
    "@supabase/supabase-js": "^2.105.1",
    "@tanstack/react-router": "^1.168.23",
    "@tanstack/react-start": "^1.167.42",
    "drizzle-orm": "^0.45.2",
    "nitro": "^3.0.260429-beta",
    "postgres": "^3.4.9",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "zod": "^4.4.1"
  },
  "devDependencies": {
    "@aws-sdk/client-sqs": "^3.1040.0",
    "@eslint/js": "^10.0.1",
    "@inlang/paraglide-js": "^2.18.0",
    "@inlang/paraglide-unplugin": "^1.9.5",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/vite": "^4.2.4",
    "@tanstack/router-cli": "^1.166.33",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/aws-lambda": "^8.10.161",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.5",
    "aws-sdk-client-mock": "^4.1.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "jsdom": "^29.0.2",
    "msw": "^2.14.2",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.2.4",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0",
    "vite": "^8.0.9",
    "vitest": "^4.1.5"
  }
}
